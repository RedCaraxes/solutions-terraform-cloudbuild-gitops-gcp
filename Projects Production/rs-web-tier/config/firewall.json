{
  "firewall_rules": {
    "allow-ssh-uc1": {
      "network": "uc1-network-prod-001",
      "description": "Allow SSH from internet",
      "direction": "INGRESS",
      "ranges": ["0.0.0.0/0"],
      "target_tags": ["ssh"],
      "allow": [
        {
          "protocol": "tcp",
          "ports": ["22"]
        }
      ]
    },
    "allow-internal-uc1": {
      "network": "uc1-network-prod-001",
      "description": "Allow internal traffic",
      "direction": "INGRESS",
      "ranges": ["10.0.0.0/8"],
      "allow": [
        {
          "protocol": "all"
        }
      ]
    },
    "deny-egress-uc2": {
      "network": "uc2-network-prod-001",
      "description": "Block internet egress",
      "direction": "EGRESS",
      "ranges": ["0.0.0.0/0"],
      "deny": [
        {
          "protocol": "all"
        }
      ]
    }
  }
}