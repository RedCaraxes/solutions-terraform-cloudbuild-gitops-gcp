{
  "firewall_rules": {
    "uc1-network-prod-001": {
      "allow-ssh-tf": {
        "description": "Allow SSH from internet",
        "direction": "INGRESS",
        "ranges": ["0.0.0.0/0"],
        "target_tags": ["ssh"],
        "allow": [{ "protocol": "tcp", "ports": ["22"] }]
      },
      "allow-internal-tf": {
        "description": "Allow internal traffic",
        "direction": "INGRESS",
        "ranges": ["10.0.0.0/8"],
        "allow": [{ "protocol": "all" }]
      }
    },
    "uc2-network-prod-001": { 
      "deny-egress-internet-tf": { 
        "description": "Block internet egress",
        "direction": "EGRESS",
        "ranges": ["0.0.0.0/0"],
        "deny": [{ "protocol": "all" }]
      }
    }
  }
}